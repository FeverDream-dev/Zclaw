# ZClaw Environment Configuration
# Copy this file to .env and fill in your values.

# --- Core ---
ZCLAW_DATA_DIR=./data
ZCLAW_HTTP_PORT=8080
ZCLAW_HEALTH_PORT=8081
ZCLAW_LOG_LEVEL=info
ZCLAW_DB_PATH=./data/zclaw.db

# --- Browser Worker ---
ZCLAW_BROWSER_WORKER_URL=http://browser-worker:9222
ZCLAW_BROWSER_PORT=9222
ZCLAW_BROWSER_POOL_SIZE=5

# --- Docker ---
ZCLAW_DOCKER_SOCKET=/var/run/docker.sock

# --- Worker Pool ---
ZCLAW_WORKER_POOL_SIZE=10

# --- Scheduler ---
ZCLAW_HEARTBEAT_JITTER_SECONDS=30

# --- Default Model ---
ZCLAW_DEFAULT_MODEL_PROVIDER=openai
ZCLAW_DEFAULT_MODEL=gpt-4o-mini

# --- Provider API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Local Providers ---
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LITELLM_BASE_URL=http://host.docker.internal:4000
# LITELLM_API_KEY=
